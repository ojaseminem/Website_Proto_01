---
const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/career', label: 'Career' },
  { href: '/about', label: 'About Us' },
  { href: '/contact', label: 'Contact Us' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="nav">
  <a class="nav__brand" href="/" aria-label="Turtle Game Works — home">
    <img src="/assets/logos/turtle-mark-white.svg" alt="" width="50" height="50" />
    <span class="nav__brand-text">Turtle&nbsp;Game&nbsp;Works</span>
  </a>

  <input type="checkbox" id="nav-toggle" class="nav__toggle" aria-hidden="true" />
  <label for="nav-toggle" class="nav__burger" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </label>

  <nav class="nav__links" aria-label="Primary">
    {links.map((l) => (
      <a href={l.href} class:list={['nav__link', { 'is-active': isActive(l.href) }]} aria-current={isActive(l.href) ? 'page' : undefined}>
        {l.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(0.8rem, 2vw, 1.4rem) var(--gutter);
    mix-blend-mode: difference; /* logo + links stay legible over any shot */
  }
  .nav__brand { display: flex; align-items: center; gap: 0.65rem; }
  .nav__brand img { width: clamp(38px, 5vw, 50px); height: auto; }
  .nav__brand-text {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--step--1);
    color: #fff;
  }
  @media (max-width: 540px) { .nav__brand-text { display: none; } }

  .nav__links { display: flex; gap: clamp(1rem, 2.5vw, 2.2rem); }
  .nav__link {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--step--1);
    color: #fff;
    position: relative;
    padding-block: 0.3rem;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    width: 100%; height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-cine);
  }
  .nav__link:hover::after,
  .nav__link.is-active::after { transform: scaleX(1); }

  /* Mobile menu — pure CSS toggle, resets on every navigation */
  .nav__toggle, .nav__burger { display: none; }

  @media (max-width: 860px) {
    .nav { mix-blend-mode: normal; }
    .nav__burger {
      display: flex; flex-direction: column; gap: 5px;
      width: 30px; height: 22px; justify-content: center;
      cursor: pointer; z-index: 51;
    }
    .nav__burger span {
      height: 2px; width: 100%; background: #fff;
      transition: transform 0.35s var(--ease-cine), opacity 0.2s;
    }
    .nav__links {
      position: fixed;
      inset: 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.4rem;
      background: rgba(8, 8, 10, 0.97);
      backdrop-filter: blur(8px);
      transform: translateY(-100%);
      transition: transform 0.5s var(--ease-cine);
      z-index: 50;
    }
    .nav__link { font-size: var(--step-1); }
    .nav__toggle:checked ~ .nav__links { transform: translateY(0); }
    .nav__toggle:checked ~ .nav__burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav__toggle:checked ~ .nav__burger span:nth-child(2) { opacity: 0; }
    .nav__toggle:checked ~ .nav__burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  }
</style>
