---
/**
 * Layered SVG key art for project cards — hand-built scene per title, so
 * placeholder cards read as intentional art direction, not missing assets.
 * Unknown slugs fall back to the abstract "open water" scene.
 * All ids are slug-prefixed; each scene renders at most once per page.
 */
interface Props {
  slug: string;
}

const { slug } = Astro.props;
const variant = ['tidebound', 'moss-and-ember', 'ironshell-tactics', 'project-drift'].includes(slug)
  ? slug
  : 'open-water';
---

{
  variant === 'tidebound' && (
    <svg viewBox="0 0 800 500" preserveAspectRatio="xMidYMid slice" role="presentation" aria-hidden="true">
      <defs>
        <linearGradient id="tb-sky" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#082530" />
          <stop offset="0.55" stop-color="#0e3a4a" />
          <stop offset="1" stop-color="#145261" />
        </linearGradient>
        <radialGradient id="tb-moon" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#d9ece8" stop-opacity="0.55" />
          <stop offset="1" stop-color="#d9ece8" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect width="800" height="500" fill="url(#tb-sky)" />
      <circle cx="590" cy="120" r="110" fill="url(#tb-moon)" />
      <circle cx="590" cy="120" r="34" fill="#d9ece8" opacity="0.85" />
      <g fill="#cfe6e1" opacity="0.5">
        <circle cx="120" cy="70" r="1.6" />
        <circle cx="210" cy="130" r="1.2" />
        <circle cx="330" cy="60" r="1.4" />
        <circle cx="450" cy="100" r="1.1" />
        <circle cx="700" cy="60" r="1.3" />
        <circle cx="80" cy="170" r="1.2" />
      </g>
      <!-- headland + lighthouse -->
      <path d="M0 320 L0 265 Q60 250 130 262 L210 285 Q260 300 300 320 Z" fill="#061e28" />
      <g fill="#061e28">
        <rect x="96" y="196" width="22" height="70" rx="2" />
        <rect x="90" y="188" width="34" height="10" rx="3" />
        <path d="M92 196 L122 196 L118 172 L96 172 Z" />
      </g>
      <rect x="99" y="176" width="16" height="12" fill="#e8a95f" opacity="0.9" rx="2" />
      <path d="M115 176 L260 150 L260 210 L115 188 Z" fill="#e8a95f" opacity="0.12" />
      <!-- water -->
      <path d="M0 320 Q200 306 420 318 T800 314 L800 500 L0 500 Z" fill="#0c3140" />
      <path d="M0 366 Q180 350 400 362 T800 358 L800 500 L0 500 Z" fill="#11424f" />
      <path d="M0 416 Q220 400 440 412 T800 408 L800 500 L0 500 Z" fill="#175360" />
      <g stroke="#3fc9be" stroke-width="2" fill="none" stroke-linecap="round">
        <path d="M60 372 q30 -8 62 0" opacity="0.35" />
        <path d="M300 360 q34 -8 66 0" opacity="0.28" />
        <path d="M560 368 q30 -8 60 0" opacity="0.35" />
        <path d="M160 424 q36 -9 70 0" opacity="0.25" />
        <path d="M470 430 q38 -9 74 0" opacity="0.3" />
        <path d="M660 470 q30 -8 62 0" opacity="0.22" />
      </g>
      <path d="M540 322 q50 -6 100 0 l-14 10 q-38 -5 -74 0 Z" fill="#d9ece8" opacity="0.16" />
    </svg>
  )
}

{
  variant === 'moss-and-ember' && (
    <svg viewBox="0 0 800 500" preserveAspectRatio="xMidYMid slice" role="presentation" aria-hidden="true">
      <defs>
        <linearGradient id="me-sky" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#141f0e" />
          <stop offset="0.6" stop-color="#24351c" />
          <stop offset="1" stop-color="#2f4522" />
        </linearGradient>
        <radialGradient id="me-glow" cx="0.5" cy="0.72" r="0.55">
          <stop offset="0" stop-color="#e8a95f" stop-opacity="0.5" />
          <stop offset="0.55" stop-color="#e8a95f" stop-opacity="0.14" />
          <stop offset="1" stop-color="#e8a95f" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect width="800" height="500" fill="url(#me-sky)" />
      <rect width="800" height="500" fill="url(#me-glow)" />
      <!-- back tree band -->
      <path d="M0 260 L40 210 L80 260 L120 190 L165 260 L200 225 L240 262 L285 200 L330 260 L0 260 Z" fill="#1a2812" opacity="0.85" transform="translate(0 -18)" />
      <path d="M470 244 L515 190 L560 244 L600 205 L645 248 L690 185 L740 248 L775 215 L800 244 L800 260 L470 260 Z" fill="#1a2812" opacity="0.85" transform="translate(0 -18)" />
      <!-- mid trees -->
      <g fill="#101c0a">
        <path d="M60 330 L110 200 L160 330 Z" />
        <rect x="102" y="322" width="16" height="40" rx="2" />
        <path d="M640 340 L695 195 L750 340 Z" />
        <rect x="687" y="330" width="16" height="44" rx="2" />
        <path d="M-20 350 L40 230 L100 350 Z" />
        <path d="M710 355 L780 240 L840 355 Z" />
      </g>
      <!-- ground -->
      <path d="M0 384 Q200 356 400 372 T800 368 L800 500 L0 500 Z" fill="#16240f" />
      <path d="M0 436 Q240 410 480 428 T800 424 L800 500 L0 500 Z" fill="#101c0a" />
      <!-- hearth cabin -->
      <g>
        <rect x="352" y="316" width="104" height="66" rx="3" fill="#0c150a" />
        <path d="M340 320 L404 278 L468 320 Z" fill="#0c150a" />
        <rect x="418" y="286" width="14" height="26" rx="2" fill="#0c150a" />
        <rect x="384" y="338" width="26" height="22" rx="2" fill="#e8a95f" opacity="0.95" />
        <rect x="384" y="338" width="26" height="22" rx="2" fill="none" stroke="#141f0e" stroke-width="2" />
        <path d="M397 338 v22 M384 349 h26" stroke="#141f0e" stroke-width="2" />
      </g>
      <path d="M425 284 q10 -14 2 -26 q12 8 8 26 Z" fill="#c4d6d2" opacity="0.25" />
      <!-- fireflies -->
      <g fill="#e8a95f">
        <circle cx="210" cy="330" r="2.6" opacity="0.8" />
        <circle cx="255" cy="300" r="1.8" opacity="0.55" />
        <circle cx="540" cy="318" r="2.4" opacity="0.75" />
        <circle cx="590" cy="288" r="1.6" opacity="0.5" />
        <circle cx="320" cy="270" r="1.7" opacity="0.5" />
        <circle cx="480" cy="252" r="1.8" opacity="0.45" />
        <circle cx="160" cy="392" r="2" opacity="0.6" />
        <circle cx="640" cy="396" r="2.2" opacity="0.6" />
      </g>
    </svg>
  )
}

{
  variant === 'ironshell-tactics' && (
    <svg viewBox="0 0 800 500" preserveAspectRatio="xMidYMid slice" role="presentation" aria-hidden="true">
      <defs>
        <linearGradient id="it-sea" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#101722" />
          <stop offset="0.6" stop-color="#1b2430" />
          <stop offset="1" stop-color="#26374a" />
        </linearGradient>
      </defs>
      <rect width="800" height="500" fill="url(#it-sea)" />
      <!-- light shafts -->
      <g fill="#93aeaa">
        <path d="M180 0 L320 0 L520 500 L360 500 Z" opacity="0.05" />
        <path d="M420 0 L500 0 L700 500 L600 500 Z" opacity="0.07" />
        <path d="M60 0 L110 0 L240 500 L170 500 Z" opacity="0.04" />
      </g>
      <!-- drowned towers -->
      <g fill="#0d141d">
        <path d="M40 500 L40 270 L70 250 L100 274 L100 500 Z" />
        <path d="M130 500 L130 320 L188 320 L188 356 L170 356 L170 500 Z" />
        <path d="M620 500 L620 230 L648 230 L648 204 L676 204 L676 240 L712 240 L712 500 Z" />
        <path d="M730 500 L730 330 L800 316 L800 500 Z" />
      </g>
      <g fill="#1c2836">
        <path d="M210 500 L210 356 L260 340 L300 362 L300 500 Z" />
        <path d="M520 500 L520 300 L560 288 L560 260 L586 260 L586 500 Z" />
        <path d="M330 500 L330 396 L400 380 L470 398 L470 500 Z" />
      </g>
      <!-- window pinpricks -->
      <g fill="#3fc9be" opacity="0.5">
        <rect x="632" y="260" width="6" height="6" rx="1" />
        <rect x="656" y="300" width="6" height="6" rx="1" />
        <rect x="688" y="270" width="6" height="6" rx="1" />
        <rect x="58" y="300" width="5" height="5" rx="1" />
        <rect x="537" y="316" width="5" height="5" rx="1" />
      </g>
      <!-- tactical floor grid, one cell lit -->
      <g stroke="#3fc9be" fill="none">
        <path d="M0 430 L800 430" opacity="0.14" />
        <path d="M0 452 L800 452" opacity="0.18" />
        <path d="M0 478 L800 478" opacity="0.14" />
        <path d="M120 418 L60 500 M280 418 L250 500 M440 418 L440 500 M600 418 L630 500 M740 418 L790 500" opacity="0.12" />
      </g>
      <path d="M440 452 L600 452 L614 478 L446 478 Z" fill="#3fc9be" opacity="0.16" stroke="#3fc9be" stroke-opacity="0.5" />
      <!-- bubbles -->
      <g stroke="#93aeaa" fill="none" opacity="0.45">
        <circle cx="705" cy="150" r="5" />
        <circle cx="690" cy="110" r="3.4" />
        <circle cx="712" cy="76" r="2.2" />
        <circle cx="150" cy="180" r="4" />
        <circle cx="163" cy="140" r="2.6" />
      </g>
    </svg>
  )
}

{
  variant === 'project-drift' && (
    <svg viewBox="0 0 800 500" preserveAspectRatio="xMidYMid slice" role="presentation" aria-hidden="true">
      <defs>
        <linearGradient id="pd-void" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#0d1017" />
          <stop offset="0.65" stop-color="#171325" />
          <stop offset="1" stop-color="#241d38" />
        </linearGradient>
        <radialGradient id="pd-glow" cx="0.7" cy="0.4" r="0.6">
          <stop offset="0" stop-color="#6c5a8f" stop-opacity="0.35" />
          <stop offset="1" stop-color="#6c5a8f" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect width="800" height="500" fill="url(#pd-void)" />
      <rect width="800" height="500" fill="url(#pd-glow)" />
      <!-- sonar contours -->
      <g stroke="#6c5a8f" fill="none">
        <ellipse cx="560" cy="200" rx="70" ry="52" opacity="0.5" />
        <ellipse cx="560" cy="200" rx="130" ry="98" opacity="0.35" />
        <ellipse cx="560" cy="200" rx="200" ry="152" opacity="0.22" />
        <ellipse cx="560" cy="200" rx="280" ry="214" opacity="0.12" />
      </g>
      <circle cx="560" cy="200" r="5" fill="#a794cf" opacity="0.9" />
      <path d="M560 200 L660 132" stroke="#a794cf" stroke-width="1.5" opacity="0.6" />
      <!-- redaction bars -->
      <g fill="#2c2440">
        <rect x="70" y="330" width="300" height="30" rx="6" />
        <rect x="70" y="378" width="220" height="30" rx="6" />
        <rect x="70" y="426" width="260" height="30" rx="6" />
      </g>
      <g fill="#3d3358">
        <rect x="82" y="340" width="120" height="10" rx="5" opacity="0.6" />
        <rect x="82" y="388" width="90" height="10" rx="5" opacity="0.6" />
        <rect x="82" y="436" width="150" height="10" rx="5" opacity="0.6" />
      </g>
      <g font-family="monospace" font-size="15" fill="#8a79ab" opacity="0.75">
        <text x="72" y="312">SIGNAL ACQUIRED — DETAILS WITHHELD</text>
      </g>
      <!-- corner ticks -->
      <g stroke="#6c5a8f" stroke-width="2" opacity="0.6" fill="none">
        <path d="M28 46 L28 28 L46 28" />
        <path d="M754 28 L772 28 L772 46" />
        <path d="M772 454 L772 472 L754 472" />
        <path d="M46 472 L28 472 L28 454" />
      </g>
    </svg>
  )
}

{
  variant === 'open-water' && (
    <svg viewBox="0 0 800 500" preserveAspectRatio="xMidYMid slice" role="presentation" aria-hidden="true">
      <defs>
        <linearGradient id="ow-sea" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#0a1c26" />
          <stop offset="1" stop-color="#24485a" />
        </linearGradient>
      </defs>
      <rect width="800" height="500" fill="url(#ow-sea)" />
      <g fill="none" stroke="#3fc9be" stroke-width="2">
        <path d="M0 200 Q200 170 400 200 T800 200" opacity="0.25" />
        <path d="M0 280 Q200 250 400 280 T800 280" opacity="0.35" />
        <path d="M0 360 Q200 330 400 360 T800 360" opacity="0.25" />
      </g>
    </svg>
  )
}
