---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: 'start' | 'center';
}

const { eyebrow, title, lede, align = 'start' } = Astro.props;
---

<header class:list={['section-heading', { center: align === 'center' }]} data-reveal>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {lede && <p class="lede">{lede}</p>}
</header>

<style>
  .section-heading {
    margin-block-end: var(--space-8);
    display: grid;
    gap: var(--space-3);
  }

  .section-heading.center {
    text-align: center;
    justify-items: center;
  }
</style>
