---
import type { Role } from '../data/roles';

interface Props {
  role: Role;
}

const { role } = Astro.props;
---

<article class="role-card" data-reveal>
  <div class="role-head">
    <h3>{role.title}</h3>
    <p class="role-meta">
      <span>{role.discipline}</span>
      <span>{role.location}</span>
      <span>{role.type}</span>
    </p>
  </div>
  <ul>
    {role.summary.map((line) => <li>{line}</li>)}
  </ul>
  <a
    class="role-apply"
    href={`mailto:${role.applyEmail}?subject=${encodeURIComponent(`Application — ${role.title}`)}`}
  >
    Apply via email →
  </a>
</article>

<style>
  .role-card {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-raised);
    transition: border-color var(--dur-base) ease;
  }

  .role-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  }

  .role-head {
    display: grid;
    gap: var(--space-2);
  }

  .role-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .role-card ul {
    display: grid;
    gap: var(--space-2);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .role-card li::marker {
    color: var(--accent);
  }

  .role-apply {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-sm);
  }
</style>
