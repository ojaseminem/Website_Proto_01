---
// The scroll companion. This renders the fixed overlay shell only —
// src/scripts/turtle.ts activates and animates it (adds .is-active).
// Without JS, with reduced motion, or on small/coarse-pointer screens
// the layer stays hidden entirely.
import turtleMark from '../assets/turtle-mark.svg?raw';
---

<div id="turtle-guide" aria-hidden="true">
  <div class="turtle-follower">
    <div class="turtle-bob">
      <Fragment set:html={turtleMark} />
    </div>
  </div>
</div>

<style>
  #turtle-guide {
    position: fixed;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    visibility: hidden;
  }

  #turtle-guide.is-active {
    visibility: visible;
  }

  .turtle-follower {
    position: absolute;
    top: 0;
    left: 0;
    inline-size: clamp(3.2rem, 5vw, 4.5rem);
    color: var(--text-muted);
    opacity: 0.55;
    will-change: transform;
  }

  @media (max-width: 767px), (pointer: coarse), (prefers-reduced-motion: reduce) {
    #turtle-guide {
      display: none;
    }
  }
</style>
