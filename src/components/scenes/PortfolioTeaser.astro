---
// Scene 5 — portfolio teaser. A few featured titles that lead into /portfolio.
const games = [
  { title: 'Project Carapace', tag: 'Action Adventure', hue: '#ff2d2d' },
  { title: 'Tidewalker', tag: 'Exploration', hue: '#2dffa6' },
  { title: 'Shellshock', tag: 'Roguelite', hue: '#2d8cff' },
];
---

<section class="folio scene">
  <div class="wrap">
    <div class="folio__head">
      <h2 class="folio__title" data-shot="rise">Selected Work</h2>
      <a class="btn" href="/portfolio" data-shot="rise">Full portfolio →</a>
    </div>
    <ul class="folio__grid">
      {games.map((g) => (
        <li class="folio__card" data-shot="rise">
          <a href="/portfolio" class="folio__link" style={`--hue:${g.hue}`}>
            <span class="folio__art"></span>
            <span class="folio__meta">
              <span class="folio__name">{g.title}</span>
              <span class="folio__tag">{g.tag}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .folio__head {
    display: flex; align-items: end; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem;
  }
  .folio__title { font-size: var(--step-2); }
  .folio__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .folio__link { display: grid; gap: 1rem; }
  .folio__art {
    display: block;
    aspect-ratio: 4 / 5;
    border-radius: 8px;
    border: 1px solid var(--ink-3);
    background:
      radial-gradient(80% 60% at 30% 15%, color-mix(in srgb, var(--hue) 50%, transparent), transparent 60%),
      linear-gradient(135deg, #16161d, #08080a 75%);
    transition: transform 0.5s var(--ease-cine), border-color 0.4s;
  }
  .folio__link:hover .folio__art { transform: translateY(-6px) scale(1.01); border-color: var(--hue); }
  .folio__meta { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .folio__name { font-family: var(--font-display); font-weight: 800; text-transform: uppercase; }
  .folio__tag { color: var(--paper-dim); font-size: var(--step--1); }
</style>
