---
// Scene 3 — the showreel. A pinned framed "screen" (the scroll/banner in the
// proto) cutting between trailers, with play, prev/next arrows and dots.
// Placeholder posters for v1; real <video> sources land via TODO.
const reels = [
  { title: 'Project Carapace — Reveal', hue: '#ff2d2d' },
  { title: 'Shellshock — Launch Trailer', hue: '#2d8cff' },
  { title: 'Tidewalker — Gameplay', hue: '#2dffa6' },
  { title: 'Studio Sizzle 2026', hue: '#b66bff' },
];
---

<section class="reel scene" id="showreel" data-cut>
  <div class="wrap">
    <p class="eyebrow" data-shot="fade">The Showreel</p>
    <h2 class="reel__heading" data-shot="rise">Press play on our worlds</h2>

    <div class="reel__stage" data-carousel data-shot="focus">
      <button class="reel__arrow reel__arrow--prev" data-prev aria-label="Previous trailer">‹</button>

      <div class="reel__frame">
        <ul class="reel__slides" data-slides>
          {reels.map((r, i) => (
            <li class="reel__slide" data-slide aria-hidden={i === 0 ? 'false' : 'true'}>
              <div class="reel__poster" style={`--hue:${r.hue}`}></div>
              <button class="reel__play" aria-label={`Play: ${r.title}`}>
                <svg viewBox="0 0 24 24" width="34" height="34" aria-hidden="true"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
              </button>
              <span class="reel__title">{r.title}</span>
            </li>
          ))}
        </ul>
      </div>

      <button class="reel__arrow reel__arrow--next" data-next aria-label="Next trailer">›</button>

      <div class="reel__dots" data-dots role="tablist" aria-label="Choose trailer">
        {reels.map((_, i) => (
          <button class="reel__dot" data-dot data-index={i} aria-label={`Go to trailer ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .reel__heading { font-size: var(--step-2); margin: 0.4rem 0 2.5rem; }
  .reel__stage {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas: 'prev frame next' 'dots dots dots';
    align-items: center;
    gap: 1rem;
  }
  .reel__frame {
    grid-area: frame;
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--ink-3);
    box-shadow: 0 30px 80px -30px rgba(0,0,0,0.8);
  }
  .reel__slides { list-style: none; padding: 0; margin: 0; height: 100%; position: relative; }
  .reel__slide {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    opacity: 0; visibility: hidden;
    transition: opacity 0.7s var(--ease-cine);
  }
  .reel__slide.is-active { opacity: 1; visibility: visible; }
  .reel__poster {
    position: absolute; inset: 0;
    background:
      radial-gradient(70% 90% at 30% 10%, color-mix(in srgb, var(--hue) 55%, transparent), transparent 60%),
      linear-gradient(135deg, #16161d, #08080a 75%);
  }
  .reel__play {
    position: relative;
    width: 86px; height: 86px;
    border-radius: 50%;
    border: 2px solid #fff;
    background: rgba(0,0,0,0.25);
    color: #fff;
    display: grid; place-items: center;
    cursor: pointer;
    backdrop-filter: blur(2px);
    transition: transform 0.4s var(--ease-cine), background 0.4s;
  }
  .reel__play:hover { transform: scale(1.08); background: var(--accent); border-color: var(--accent); }
  .reel__play svg { margin-left: 4px; }
  .reel__title {
    position: absolute; left: 1.2rem; bottom: 1.2rem;
    font-family: var(--font-display);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    font-size: var(--step--1);
  }
  .reel__arrow {
    width: 54px; height: 54px; border-radius: 50%;
    border: 1px solid var(--ink-3); background: var(--ink-2); color: var(--paper);
    font-size: 2rem; line-height: 1; cursor: pointer;
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }
  .reel__arrow--prev { grid-area: prev; }
  .reel__arrow--next { grid-area: next; }
  .reel__arrow:hover { background: var(--accent); border-color: var(--accent); color: #fff; }

  .reel__dots { grid-area: dots; display: flex; gap: 0.6rem; justify-content: center; margin-top: 1.4rem; }
  .reel__dot {
    width: 10px; height: 10px; border-radius: 50%;
    border: none; background: var(--ink-3); cursor: pointer; padding: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .reel__dot.is-active { background: var(--accent); transform: scale(1.3); }

  @media (max-width: 620px) {
    .reel__arrow { width: 44px; height: 44px; font-size: 1.5rem; }
    .reel__play { width: 64px; height: 64px; }
  }
</style>

<script>
  function initCarousel(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-dot]'));
    if (!slides.length) return;
    let index = 0;
    let timer: number | undefined;

    const render = () => {
      slides.forEach((s, i) => {
        const active = i === index;
        s.classList.toggle('is-active', active);
        s.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach((d, i) => d.classList.toggle('is-active', i === index));
    };
    const go = (i: number) => { index = (i + slides.length) % slides.length; render(); restart(); };
    const restart = () => {
      window.clearInterval(timer);
      timer = window.setInterval(() => go(index + 1), 6000);
    };

    root.querySelector('[data-prev]')?.addEventListener('click', () => go(index - 1));
    root.querySelector('[data-next]')?.addEventListener('click', () => go(index + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => go(i)));

    render();
    restart();
  }

  function boot() {
    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
  }
  document.addEventListener('astro:page-load', boot);
</script>
