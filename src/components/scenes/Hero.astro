---
// Scene 1 — establishing shot. A framed slab of "key art" that dollies in as
// you scroll, with the featured-title copy alongside.
---

<section class="hero scene">
  <div class="wrap hero__grid">
    <div class="hero__copy">
      <p class="eyebrow" data-shot="rise">Now in development</p>
      <h2 class="hero__title" data-shot="rise">Project<br />Carapace</h2>
      <p class="hero__lede" data-shot="rise">
        A story-driven action adventure forged in our own engine. One world,
        countless ways through it.
      </p>
      <a class="btn" href="/portfolio" data-shot="rise">See the work →</a>
    </div>

    <div class="hero__art" data-shot="dolly" aria-hidden="true">
      <div class="hero__art-inner" data-parallax="0.15"></div>
      <span class="hero__art-tag">Key Art — Placeholder</span>
    </div>
  </div>
</section>

<style>
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }
  @media (max-width: 820px) { .hero__grid { grid-template-columns: 1fr; } }

  .hero__title { font-size: var(--step-3); margin: 0.4rem 0 1.2rem; }
  .hero__lede { color: var(--paper-dim); max-width: 42ch; margin-bottom: 2rem; }

  .hero__art {
    position: relative;
    aspect-ratio: 16 / 11;
    border: 1px solid var(--ink-3);
    border-radius: 6px;
    overflow: hidden;
    /* trapezoidal "cinema" framing nodding to the proto sketch */
    clip-path: polygon(6% 0, 94% 0, 100% 100%, 0% 100%);
  }
  .hero__art-inner {
    position: absolute;
    inset: -10%;
    background:
      radial-gradient(80% 60% at 30% 20%, rgba(255,45,45,0.35), transparent 60%),
      linear-gradient(135deg, #1d1d27, #0b0b10 70%);
  }
  .hero__art-tag {
    position: absolute;
    bottom: 1rem; right: 1rem;
    font-family: var(--font-display);
    font-size: var(--step--1);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--paper-dim);
  }
</style>
