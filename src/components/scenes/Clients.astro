---
// Scene 4 — CLIENTS. Big type, logos resolve from the dark (rack focus).
const clients = ['NORTHWIND', 'AETHER', 'KOJI', 'VANTA', 'HELIOS', 'MERIDIAN'];
---

<section class="clients scene" data-cut>
  <div class="wrap">
    <h2 class="clients__title" data-shot="rise">Clients</h2>
    <p class="clients__lede" data-shot="rise">
      Studios and publishers we've built alongside.
    </p>
    <ul class="clients__grid">
      {clients.map((c) => (
        <li class="clients__cell" data-shot="focus">{c}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  .clients__title { font-size: var(--step-4); }
  .clients__lede { color: var(--paper-dim); margin: 0.6rem 0 3rem; max-width: 40ch; }
  .clients__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1px;
    background: var(--ink-3);
    border: 1px solid var(--ink-3);
  }
  .clients__cell {
    background: var(--ink);
    display: grid; place-items: center;
    min-height: 130px;
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--paper-dim);
    transition: color 0.4s, background 0.4s;
  }
  .clients__cell:hover { color: var(--paper); background: var(--ink-2); }
</style>
