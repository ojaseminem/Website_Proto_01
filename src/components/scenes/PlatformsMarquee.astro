---
// Scene 2 — the small icon row from the proto. A horizontal credentials drift:
// platforms we ship to. Content is duplicated so the loop is seamless.
const items = ['Steam', 'PlayStation', 'Xbox', 'Nintendo Switch', 'Epic Games', 'PC / Win', 'iOS', 'Android'];
const loop = [...items, ...items];
---

<section class="marquee">
  <p class="marquee__label eyebrow">Shipping across</p>
  <div class="marquee__viewport">
    <div class="marquee__track" data-marquee>
      {loop.map((label) => (
        <span class="marquee__chip">{label}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    padding-block: clamp(2.5rem, 8vh, 5rem);
    border-block: 1px solid var(--ink-3);
    overflow: hidden;
  }
  .marquee__label { text-align: center; margin-bottom: 1.6rem; }
  .marquee__viewport {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
            mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
  }
  .marquee__track { display: flex; gap: 3.5rem; width: max-content; will-change: transform; }
  .marquee__chip {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--step-1);
    color: var(--paper-dim);
    white-space: nowrap;
    transition: color 0.3s;
  }
  .marquee__chip:hover { color: var(--paper); }
</style>
