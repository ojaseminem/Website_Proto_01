---
// Flips html[data-theme], persists to localStorage. The inline head script
// in BaseLayout owns the initial value, so this only ever toggles.
---

<button
  type="button"
  class="theme-toggle"
  id="theme-toggle"
  aria-label="Switch color theme"
  title="Switch theme"
>
  <svg
    class="icon-sun"
    viewBox="0 0 24 24"
    width="18"
    height="18"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4.2"></circle>
    <path
      d="M12 2.5v2.4M12 19.1v2.4M2.5 12h2.4M19.1 12h2.4M5 5l1.7 1.7M17.3 17.3 19 19M19 5l-1.7 1.7M6.7 17.3 5 19"
    ></path>
  </svg>
  <svg
    class="icon-moon"
    viewBox="0 0 24 24"
    width="18"
    height="18"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M20.6 14.4A8.6 8.6 0 0 1 9.6 3.4a8.6 8.6 0 1 0 11 11Z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    inline-size: 2.4rem;
    block-size: 2.4rem;
    border-radius: 50%;
    color: var(--text-muted);
    border: 1px solid var(--border);
    transition: color var(--dur-fast) ease, border-color var(--dur-fast) ease;
  }

  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  html[data-theme='dark'] .icon-moon,
  html[data-theme='light'] .icon-sun {
    display: none;
  }
</style>

<script>
  // One delegated listener, bound a single time per bundle load. Binding to
  // the button directly and re-binding on astro:page-load double-fires on the
  // initial load (page-load fires there too), toggling the theme twice per
  // click — i.e. visibly not at all.
  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Element) || !event.target.closest('#theme-toggle')) {
      return;
    }
    const next =
      document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('tgw-theme', next);
  });
</script>
