---
// Cinematic opening shot for inner pages: eyebrow + oversized title + lede,
// over the same dark frame, with a fade-to-black cut as it settles.
interface Props { eyebrow: string; title: string; lede?: string; }
const { eyebrow, title, lede } = Astro.props;
---

<section class="pintro scene" data-cut>
  <div class="wrap">
    <p class="eyebrow" data-shot="fade">{eyebrow}</p>
    <h1 class="pintro__title" data-shot="rise">{title}</h1>
    {lede && <p class="pintro__lede" data-shot="rise">{lede}</p>}
  </div>
</section>

<style>
  .pintro { min-height: 78svh; align-content: center; background: radial-gradient(120% 90% at 30% 25%, #15151c 0%, var(--ink) 60%); }
  .pintro__title { font-size: var(--step-4); margin-top: 0.3rem; }
  .pintro__lede { color: var(--paper-dim); font-size: var(--step-1); max-width: 46ch; margin-top: 1.4rem; }
</style>
