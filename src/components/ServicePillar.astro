---
import type { Service } from '../data/services';

interface Props {
  service: Service;
  compact?: boolean;
}

const { service, compact = false } = Astro.props;
---

<article class:list={['pillar', { compact }]} data-reveal>
  <h3>{service.title}</h3>
  <p class="tagline">{service.tagline}</p>
  {
    !compact && (
      <>
        <p class="desc">{service.description}</p>
        <ul>
          {service.capabilities.map((cap) => (
            <li>{cap}</li>
          ))}
        </ul>
        <p class="engagement">{service.engagement}</p>
      </>
    )
  }
</article>

<style>
  .pillar {
    display: grid;
    gap: var(--space-3);
    align-content: start;
    padding: var(--space-6);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-raised);
    transition: border-color var(--dur-base) ease, transform var(--dur-base) var(--ease-drift);
  }

  .pillar:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    transform: translateY(-4px);
  }

  .tagline {
    color: var(--accent);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .desc {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .pillar ul {
    display: grid;
    gap: var(--space-2);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .pillar li::marker {
    color: var(--accent);
  }

  .engagement {
    font-size: var(--text-xs);
    color: var(--text-faint);
    border-block-start: 1px solid var(--border);
    padding-block-start: var(--space-3);
  }
</style>
