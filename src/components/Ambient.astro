---
// Ambient "descent" layer that turns the scroll into an underwater playthrough.
// Sits behind all content: drifting particle field, god rays up top that fade
// as you go deeper, and a depth gradient + vignette that intensifies with
// scroll (--depth). Palette stays ink/white only. Off under reduced motion.
---

<div class="amb" aria-hidden="true">
  <div class="amb__rays"></div>
  <canvas class="amb__canvas" data-fx></canvas>
  <div class="amb__deepen"></div>
  <div class="amb__vignette"></div>
</div>

<style>
  .amb { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .amb__rays {
    position: absolute; inset: 0 0 auto 0; height: 75vh;
    background: linear-gradient(102deg,
      transparent 0 16%, rgba(255,255,255,.05) 17% 18%, transparent 19% 36%,
      rgba(255,255,255,.04) 37% 38%, transparent 39% 58%, rgba(255,255,255,.055) 59% 60%,
      transparent 61% 80%, rgba(255,255,255,.04) 81% 82%, transparent 83%);
    -webkit-mask-image: linear-gradient(#000, transparent);
            mask-image: linear-gradient(#000, transparent);
    opacity: calc(0.85 - var(--depth, 0) * 1.25);
    mix-blend-mode: screen;
  }
  .amb__canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .amb__deepen { position: absolute; inset: 0; background: #01030b; opacity: calc(var(--depth, 0) * 0.55); }
  .amb__vignette {
    position: absolute; inset: 0;
    background: radial-gradient(120% 90% at 50% 38%, transparent 42%, rgba(0,0,0,.6) 100%);
    opacity: calc(0.32 + var(--depth, 0) * 0.5);
  }
  @media (prefers-reduced-motion: reduce) {
    .amb__canvas { display: none; }
  }
</style>

<script>
  type P = { x: number; y: number; r: number; sp: number; dx: number; a: number; ring: boolean };

  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let parts: P[] = [];
  let w = 0, hh = 0, dpr = 1, raf = 0, sraf = 0;
  let onResize: (() => void) | null = null;
  let onScroll: (() => void) | null = null;
  let reduce = false;

  function size() {
    if (!canvas) return;
    dpr = Math.min(2, window.devicePixelRatio || 1);
    w = canvas.width = Math.floor(window.innerWidth * dpr);
    hh = canvas.height = Math.floor(window.innerHeight * dpr);
    canvas.style.width = window.innerWidth + 'px';
    canvas.style.height = window.innerHeight + 'px';
  }
  function seed() {
    const n = Math.round(window.innerWidth / 24);
    parts = [];
    for (let i = 0; i < n; i++) {
      parts.push({
        x: Math.random() * w, y: Math.random() * hh,
        r: (Math.random() * 1.6 + 0.4) * dpr,
        sp: (Math.random() * 0.4 + 0.15) * dpr,
        dx: (Math.random() - 0.5) * 0.25 * dpr,
        a: Math.random() * 0.09 + 0.03,
        ring: Math.random() < 0.18,
      });
    }
  }
  function frame() {
    if (!ctx) return;
    ctx.clearRect(0, 0, w, hh);
    for (const p of parts) {
      p.y -= p.sp; p.x += p.dx + Math.sin(p.y * 0.01) * 0.2 * dpr;
      if (p.y < -10) { p.y = hh + 10; p.x = Math.random() * w; }
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      if (p.ring) { ctx.strokeStyle = `rgba(255,255,255,${p.a})`; ctx.lineWidth = dpr; ctx.stroke(); }
      else { ctx.fillStyle = `rgba(255,255,255,${p.a})`; ctx.fill(); }
    }
    raf = requestAnimationFrame(frame);
  }
  function start() { if (!raf && !document.hidden) raf = requestAnimationFrame(frame); }
  function stop() { if (raf) cancelAnimationFrame(raf); raf = 0; }

  function depth() {
    const max = document.documentElement.scrollHeight - window.innerHeight;
    const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
    document.documentElement.style.setProperty('--depth', p.toFixed(3));
  }

  function boot() {
    canvas = document.querySelector<HTMLCanvasElement>('[data-fx]');
    reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    depth();
    onScroll = () => { if (!sraf) sraf = requestAnimationFrame(() => { sraf = 0; depth(); }); };
    window.addEventListener('scroll', onScroll, { passive: true });
    if (!canvas || reduce) return;
    ctx = canvas.getContext('2d');
    size(); seed(); start();
    onResize = () => { size(); seed(); };
    window.addEventListener('resize', onResize, { passive: true });
    document.addEventListener('visibilitychange', vis);
  }
  function vis() { if (document.hidden) stop(); else start(); }

  function teardown() {
    stop();
    if (sraf) cancelAnimationFrame(sraf); sraf = 0;
    if (onScroll) window.removeEventListener('scroll', onScroll);
    if (onResize) window.removeEventListener('resize', onResize);
    document.removeEventListener('visibilitychange', vis);
    onScroll = onResize = null; canvas = null; ctx = null; parts = [];
  }

  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:before-swap', teardown);
</script>
