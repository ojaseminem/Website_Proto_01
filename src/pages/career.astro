---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';

const roles = [
  { title: 'Senior Gameplay Engineer', team: 'Engineering', loc: 'Remote / Hybrid' },
  { title: 'Technical Artist', team: 'Art', loc: 'Remote' },
  { title: 'Narrative Designer', team: 'Design', loc: 'Hybrid' },
  { title: 'Producer', team: 'Production', loc: 'Remote' },
];
---

<BaseLayout title="Career — Turtle Game Works" description="Open roles at Turtle Game Works. Build worlds with us.">
  <PageIntro eyebrow="Join the studio" title="Career" lede="Small team, big worlds. We hire for craft, curiosity and care." />

  <section class="jobs scene">
    <div class="wrap">
      <ul class="jobs__list">
        {roles.map((r) => (
          <li class="jobs__row" data-shot="rise">
            <span class="jobs__title">{r.title}</span>
            <span class="jobs__team">{r.team}</span>
            <span class="jobs__loc">{r.loc}</span>
            <a class="jobs__apply" href="/contact" aria-label={`Apply for ${r.title}`}>Apply →</a>
          </li>
        ))}
      </ul>
      <p class="jobs__note" data-shot="fade">
        Don't see your role? Send an open application to
        <a href="mailto:jobs@turtlegameworks.com">jobs@turtlegameworks.com</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .jobs__list { list-style: none; margin: 0; padding: 0; }
  .jobs__row {
    display: grid; grid-template-columns: 2fr 1fr 1fr auto; gap: 1.5rem; align-items: center;
    padding-block: 1.6rem; border-top: 1px solid var(--ink-3);
  }
  .jobs__row:last-child { border-bottom: 1px solid var(--ink-3); }
  @media (max-width: 720px) { .jobs__row { grid-template-columns: 1fr auto; gap: 0.4rem 1rem; } .jobs__team, .jobs__loc { color: var(--paper-dim); font-size: var(--step--1); } }
  .jobs__title { font-family: var(--font-display); font-weight: 800; text-transform: uppercase; font-size: var(--step-1); }
  .jobs__team, .jobs__loc { color: var(--paper-dim); }
  .jobs__apply { color: var(--accent); font-family: var(--font-display); font-weight: 700; white-space: nowrap; }
  .jobs__note { margin-top: 2.5rem; color: var(--paper-dim); }
  .jobs__note a { color: var(--accent); }
</style>
