---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';

// v1 is intentionally light — direct email + socials, no backend.
// A real form (Cloudflare Pages Function + Turnstile) is tracked in TODO.md.
const channels = [
  { label: 'Projects & partnerships', value: 'hello@turtlegameworks.com', href: 'mailto:hello@turtlegameworks.com' },
  { label: 'Careers', value: 'jobs@turtlegameworks.com', href: 'mailto:jobs@turtlegameworks.com' },
  { label: 'Press', value: 'press@turtlegameworks.com', href: 'mailto:press@turtlegameworks.com' },
];
const socials = [
  { label: 'YouTube', href: 'https://www.youtube.com' },
  { label: 'Discord', href: 'https://discord.com' },
  { label: 'X', href: 'https://x.com' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com' },
];
---

<BaseLayout title="Contact — Turtle Game Works" description="Get in touch with Turtle Game Works about projects, careers and press.">
  <PageIntro eyebrow="Say hello" title="Contact Us" lede="Tell us what you're dreaming up. We read everything." />

  <section class="contact scene">
    <div class="wrap contact__grid">
      <div class="contact__channels">
        {channels.map((c) => (
          <a class="contact__channel" href={c.href} data-shot="rise">
            <span class="contact__label">{c.label}</span>
            <span class="contact__value">{c.value}</span>
          </a>
        ))}
      </div>

      <aside class="contact__socials" data-shot="rise">
        <h2 class="contact__heading">Elsewhere</h2>
        <ul>
          {socials.map((s) => (
            <li><a href={s.href} target="_blank" rel="noopener noreferrer">{s.label} ↗</a></li>
          ))}
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__grid { display: grid; grid-template-columns: 2fr 1fr; gap: clamp(2rem, 6vw, 5rem); }
  @media (max-width: 760px) { .contact__grid { grid-template-columns: 1fr; } }
  .contact__channels { display: grid; gap: 1px; background: var(--ink-3); border: 1px solid var(--ink-3); }
  .contact__channel {
    background: var(--ink); display: grid; gap: 0.4rem; padding: clamp(1.4rem, 4vw, 2.4rem);
    transition: background 0.4s;
  }
  .contact__channel:hover { background: var(--ink-2); }
  .contact__label { color: var(--paper-dim); font-size: var(--step--1); letter-spacing: 0.1em; text-transform: uppercase; }
  .contact__value { font-family: var(--font-display); font-weight: 800; font-size: var(--step-1); }
  .contact__channel:hover .contact__value { color: var(--accent); }
  .contact__heading { font-size: var(--step--1); letter-spacing: 0.3em; color: var(--paper-dim); margin-bottom: 1rem; }
  .contact__socials ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.8rem; }
  .contact__socials a { font-family: var(--font-display); font-weight: 700; text-transform: uppercase; }
  .contact__socials a:hover { color: var(--accent); }
</style>
