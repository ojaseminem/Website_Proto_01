---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';

const stats = [
  { k: '10+', v: 'Years building games' },
  { k: '24', v: 'Titles shipped & co-dev' },
  { k: '30', v: 'Turtles on the team' },
];
const values = [
  { title: 'Worlds first', body: 'Systems serve the world, not the other way round. If it doesn\'t deepen the place, it doesn\'t ship.' },
  { title: 'Slow is smooth', body: 'We move deliberately like our namesake — and that\'s exactly why we go the distance.' },
  { title: 'Craft over noise', body: 'No crunch theatrics. Real polish, sustainable pace, work we\'re proud to sign.' },
];
---

<BaseLayout title="About — Turtle Game Works" description="Who we are: an independent studio building cinematic, story-driven games.">
  <PageIntro eyebrow="Who we are" title="About Us" lede="Turtle Game Works is an independent studio. We build cinematic, story-driven games — and we take our time getting them right." />

  <section class="about scene">
    <div class="wrap">
      <ul class="about__stats" data-shot="rise">
        {stats.map((s) => (
          <li><span class="about__k">{s.k}</span><span class="about__v">{s.v}</span></li>
        ))}
      </ul>

      <div class="about__values">
        {values.map((v) => (
          <article class="about__value" data-shot="rise">
            <h2 class="about__vt">{v.title}</h2>
            <p class="about__vb">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about__stats {
    list-style: none; margin: 0 0 4rem; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    border-block: 1px solid var(--ink-3);
  }
  @media (max-width: 620px) { .about__stats { grid-template-columns: 1fr; } }
  .about__stats li { display: grid; gap: 0.3rem; padding-block: 2rem; }
  .about__k { font-family: var(--font-display); font-weight: 800; font-size: var(--step-3); color: var(--accent); line-height: 1; }
  .about__v { color: var(--paper-dim); }
  .about__values { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 2rem; }
  .about__vt { font-size: var(--step-1); margin-bottom: 0.6rem; }
  .about__vb { color: var(--paper-dim); }
</style>
