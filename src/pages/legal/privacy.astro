---
import PolicyLayout from '../../layouts/PolicyLayout.astro';
import { site } from '../../data/site';

const toc = [
  { id: 'scope', label: 'Scope' },
  { id: 'data-we-collect', label: 'Data we collect' },
  { id: 'how-we-use-data', label: 'How we use data' },
  { id: 'sharing', label: 'Sharing & third parties' },
  { id: 'retention', label: 'Retention' },
  { id: 'deletion', label: 'Your rights & deletion' },
  { id: 'children', label: 'Children’s privacy' },
  { id: 'per-game', label: 'Per-game annexes' },
  { id: 'changes', label: 'Changes' },
  { id: 'contact', label: 'Contact' },
];
---

<PolicyLayout
  title="Privacy Policy"
  description="How Turtle Game Works collects, uses and protects personal data across our games and website."
  effectiveDate="July 4, 2026"
  {toc}
>
  <section id="scope">
    <h2>Scope</h2>
    <p>
      This Privacy Policy covers {site.name} ("we", "us") — our website and our
      games published on PC storefronts (including Steam), consoles, Google
      Play, and the Apple App Store. Where an individual game has additional
      practices, they are listed in its per-game annex below.
    </p>
  </section>

  <section id="data-we-collect">
    <h2>Data we collect</h2>
    <h3>On this website</h3>
    <ul>
      <li>
        <strong>No tracking.</strong> We run no analytics, advertising, or
        tracking cookies on this site. The only thing stored on your device is
        a <code>localStorage</code> entry remembering your light/dark theme
        preference. It never leaves your browser.
      </li>
      <li>
        <strong>Email you send us.</strong> If you contact us, we receive what
        you send (your address and message) and use it only to respond.
      </li>
    </ul>
    <h3>In our games</h3>
    <ul>
      <li><strong>Account data</strong> — an identifier, display name and email where a game offers accounts.</li>
      <li><strong>Purchase records</strong> — receipts from the platform store (we never see full payment details; stores process all payments).</li>
      <li><strong>Gameplay & device telemetry</strong> — crash reports, session and progression data used to fix bugs and balance the game.</li>
      <li><strong>Support correspondence</strong> — what you send our support inboxes.</li>
    </ul>
  </section>

  <section id="how-we-use-data">
    <h2>How we use data</h2>
    <ul>
      <li>Operating games and services you asked for (accounts, saves, purchases).</li>
      <li>Fixing crashes, cheating and abuse.</li>
      <li>Balancing and improving games via aggregated telemetry.</li>
      <li>Responding to support and legal requests.</li>
    </ul>
    <p>We do not sell personal data. We do not use personal data for third-party advertising.</p>
  </section>

  <section id="sharing">
    <h2>Sharing &amp; third parties</h2>
    <p>
      We share data only with processors necessary to run our games — platform
      services (Steam, Google Play, App Store, console networks), crash
      reporting, and cloud hosting — under contracts limiting their use to our
      instructions. We disclose data if required by law.
    </p>
  </section>

  <section id="retention">
    <h2>Retention</h2>
    <p>
      Account and gameplay data is kept while your account is active and for up
      to 90 days after deletion is requested (backup cycling). Purchase records
      are kept as long as tax and consumer law requires. Support threads are
      kept for 24 months.
    </p>
  </section>

  <section id="deletion">
    <h2>Your rights &amp; deletion</h2>
    <p>
      You may request access to, correction of, or deletion of your personal
      data. Email the relevant game's support address (listed on our Support
      page) or {site.emails.support} from the email linked to your account.
      We confirm within 2 business days and complete deletion within 30 days,
      except records we must keep by law.
    </p>
  </section>

  <section id="children">
    <h2>Children’s privacy</h2>
    <p>
      Our games are not directed at children under 13 (or the applicable age of
      digital consent in your region), and we do not knowingly collect personal
      data from them. If you believe a child has provided us personal data,
      contact us and we will delete it.
    </p>
  </section>

  <section id="per-game">
    <h2>Per-game annexes</h2>
    <h3>Moss &amp; Ember</h3>
    <ul>
      <li>Optional account for cross-device saves (identifier, display name, email).</li>
      <li>Seasonal-event participation telemetry, aggregated.</li>
      <li>Data deletion: see the Support page panel for exact steps.</li>
    </ul>
    <p>Future titles will be listed here at or before launch.</p>
  </section>

  <section id="changes">
    <h2>Changes</h2>
    <p>
      We will post any changes here with an updated effective date, and for
      material changes affecting live games we will notify players in-game or
      by email where possible.
    </p>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p>
      Privacy questions: <a href={`mailto:${site.emails.support}`}>{site.emails.support}</a>
      {' '}(subject "Privacy"). {site.location}.
    </p>
  </section>
</PolicyLayout>
