---
import PolicyLayout from '../../layouts/PolicyLayout.astro';
import { site } from '../../data/site';
import { withBase } from '../../lib/url';

const toc = [
  { id: 'acceptance', label: 'Acceptance' },
  { id: 'services', label: 'Our services' },
  { id: 'accounts', label: 'Accounts' },
  { id: 'conduct', label: 'Acceptable conduct' },
  { id: 'purchases', label: 'Purchases & virtual items' },
  { id: 'ip', label: 'Intellectual property' },
  { id: 'ugc', label: 'User content & streaming' },
  { id: 'disclaimers', label: 'Disclaimers & liability' },
  { id: 'termination', label: 'Termination' },
  { id: 'governing-law', label: 'Governing law' },
  { id: 'contact', label: 'Contact' },
];
---

<PolicyLayout
  title="Terms of Service"
  description="The terms that govern use of Turtle Game Works games, websites and services."
  effectiveDate="July 4, 2026"
  {toc}
>
  <section id="acceptance">
    <h2>Acceptance</h2>
    <p>
      These Terms of Service ("Terms") are an agreement between you and
      {site.name} covering our websites, games and related services
      (together, the "Services"). By using the Services you accept these Terms
      and our <a href={withBase('legal/privacy/')}>Privacy Policy</a>. Game
      software is additionally licensed under the
      <a href={withBase('legal/eula/')}>EULA</a>.
    </p>
  </section>

  <section id="services">
    <h2>Our services</h2>
    <p>
      We operate original games and, for live titles, ongoing services such as
      events, storage of saves, and in-game economies. Live features evolve:
      content, balance and availability may change over time as part of
      operating the game responsibly.
    </p>
  </section>

  <section id="accounts">
    <h2>Accounts</h2>
    <ul>
      <li>You must provide accurate information and keep credentials secure.</li>
      <li>You are responsible for activity under your account.</li>
      <li>You must meet the minimum age in your region (at least 13).</li>
      <li>Platform accounts (Steam, Google Play, Apple, console networks) are governed by their own terms in addition to ours.</li>
    </ul>
  </section>

  <section id="conduct">
    <h2>Acceptable conduct</h2>
    <p>You agree not to:</p>
    <ul>
      <li>Cheat, exploit, use unauthorized automation, or tamper with game clients or servers.</li>
      <li>Harass, threaten or abuse other players or our staff.</li>
      <li>Buy, sell or transfer accounts or virtual items outside mechanisms we provide.</li>
      <li>Reverse-engineer or redistribute the Services except where law expressly permits.</li>
    </ul>
  </section>

  <section id="purchases">
    <h2>Purchases &amp; virtual items</h2>
    <p>
      Purchases are processed by the store you buy from (Steam, Google Play,
      the App Store, console stores); their refund policies apply. Virtual
      items and currencies are a limited, revocable license to use features of
      the game — they have no cash value and are not transferable. If a
      purchase fails to arrive in-game, contact support and we will restore or
      refund it.
    </p>
  </section>

  <section id="ip">
    <h2>Intellectual property</h2>
    <p>
      The Services, including our games, characters, art, music, trademarks and
      the Turtle Game Works name and mark, are owned by {site.name} or our
      licensors. No rights are granted except as stated in these Terms and the
      EULA.
    </p>
  </section>

  <section id="ugc">
    <h2>User content &amp; streaming</h2>
    <p>
      You keep ownership of content you create (screenshots, videos, streams,
      fan art) but grant us a non-exclusive, worldwide, royalty-free license to
      host and display content you submit through the Services. Monetized
      videos and streams featuring our games are welcome, provided you don't
      imply our endorsement or resell access to the games.
    </p>
  </section>

  <section id="disclaimers">
    <h2>Disclaimers &amp; liability</h2>
    <p>
      The Services are provided "as is" without warranties beyond those that
      cannot be excluded by law. To the maximum extent permitted by law, our
      total liability for any claim relating to the Services is limited to the
      amount you paid us in the 12 months before the claim. Nothing in these
      Terms limits liability that cannot lawfully be limited, and nothing
      affects consumer rights that apply in your country.
    </p>
  </section>

  <section id="termination">
    <h2>Termination</h2>
    <p>
      You may stop using the Services at any time and may request account
      deletion via the Support page. We may suspend or terminate accounts that
      materially breach these Terms (including cheating and abuse), with notice
      where practicable. If we retire a live game, we will give reasonable
      advance notice.
    </p>
  </section>

  <section id="governing-law">
    <h2>Governing law</h2>
    <p>
      These Terms are governed by the laws of India, without prejudice to
      mandatory consumer protections of your place of residence. Disputes will
      be resolved in the courts of Hyderabad, Telangana, unless applicable law
      requires otherwise.
    </p>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p>
      Questions about these Terms:
      <a href={`mailto:${site.emails.hello}`}>{site.emails.hello}</a>.
    </p>
  </section>
</PolicyLayout>
