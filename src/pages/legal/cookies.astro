---
import PolicyLayout from '../../layouts/PolicyLayout.astro';
import { site } from '../../data/site';

const toc = [
  { id: 'summary', label: 'The short version' },
  { id: 'what-we-store', label: 'What we store' },
  { id: 'what-we-dont', label: 'What we don’t do' },
  { id: 'managing', label: 'Managing storage' },
  { id: 'changes', label: 'Changes' },
];
---

<PolicyLayout
  title="Cookie Notice"
  description="What the Turtle Game Works website stores on your device — spoiler: almost nothing."
  effectiveDate="July 4, 2026"
  {toc}
>
  <section id="summary">
    <h2>The short version</h2>
    <p>
      This website uses <strong>no cookies</strong> — no analytics, no
      advertising, no tracking of any kind. That's why you don't see a cookie
      banner.
    </p>
  </section>

  <section id="what-we-store">
    <h2>What we store</h2>
    <ul>
      <li>
        <strong><code>tgw-theme</code></strong> (localStorage) — remembers
        whether you prefer the light or dark theme. Stored only in your
        browser, never transmitted to us, and deleted whenever you clear site
        data.
      </li>
    </ul>
  </section>

  <section id="what-we-dont">
    <h2>What we don’t do</h2>
    <ul>
      <li>No first- or third-party tracking cookies.</li>
      <li>No analytics or fingerprinting.</li>
      <li>No advertising or social-media pixels.</li>
      <li>No sharing of browsing data — we never receive it in the first place.</li>
    </ul>
    <p>
      Our games may use their own storage as described in the Privacy Policy
      and their platform store listings.
    </p>
  </section>

  <section id="managing">
    <h2>Managing storage</h2>
    <p>
      You can clear the theme preference (and anything else a site stores) via
      your browser's site-data settings. The site works fine without it — it
      just forgets your theme choice.
    </p>
  </section>

  <section id="changes">
    <h2>Changes</h2>
    <p>
      If we ever add anything that stores or processes more than the above
      (for example, an embedded video player), we will update this notice
      first and add consent controls where required. Questions:
      <a href={`mailto:${site.emails.hello}`}>{site.emails.hello}</a>.
    </p>
  </section>
</PolicyLayout>
