---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';

const services = [
  { n: '01', title: 'Original IP', body: 'We conceive, prototype and ship our own games — from first spark to launch and live-ops.' },
  { n: '02', title: 'Co-Development', body: 'Drop-in production muscle: gameplay, tools, engine work, and content at scale alongside your team.' },
  { n: '03', title: 'Art & Animation', body: 'Concept, 3D, technical art and cinematics — a visual language that makes your world feel inevitable.' },
  { n: '04', title: 'Engineering', body: 'Custom engines and pipelines, performance, and platform delivery across console, PC and mobile.' },
];
---

<BaseLayout title="Services — Turtle Game Works" description="Original IP, co-development, art and engineering services from Turtle Game Works.">
  <PageIntro
    eyebrow="What we do"
    title="Services"
    lede="A full-stack studio. We can take a concept all the way to the storefront — or strengthen the team you already have."
  />

  <section class="svc scene">
    <div class="wrap">
      <ul class="svc__list">
        {services.map((s) => (
          <li class="svc__row" data-shot="rise">
            <span class="svc__n">{s.n}</span>
            <h2 class="svc__title">{s.title}</h2>
            <p class="svc__body">{s.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .svc__list { list-style: none; margin: 0; padding: 0; }
  .svc__row {
    display: grid;
    grid-template-columns: 80px 1fr 2fr;
    gap: clamp(1rem, 4vw, 3rem);
    align-items: baseline;
    padding-block: clamp(1.8rem, 5vh, 3rem);
    border-top: 1px solid var(--ink-3);
  }
  .svc__row:last-child { border-bottom: 1px solid var(--ink-3); }
  @media (max-width: 720px) { .svc__row { grid-template-columns: 1fr; gap: 0.6rem; } }
  .svc__n { font-family: var(--font-display); color: var(--accent); font-weight: 800; }
  .svc__title { font-size: var(--step-2); }
  .svc__body { color: var(--paper-dim); max-width: 48ch; }
</style>
